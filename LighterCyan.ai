--// Safety wrapper for external loader
pcall(function()
    if type(loadstring) == "function" and game and type(game.HttpGet) == "function" then
        local ok, result = pcall(function()
            return game:HttpGet("https://raw.githubusercontent.com/White-rbx/LigherCyan.ai/refs/heads/main/Loader.lua")
        end)
        if ok and result then
            local ok2, err = pcall(loadstring, result)
            if ok2 then
                pcall(function() err() end)
            end
        end
    end
end)

--// Services with safe access
local Players, CoreGui, HttpService, TextService
