--// resize helper (declared after Scroll exists, but function is forward-declared above)
local function safe_attach_auto_resize(frame, label)
    if not (frame and frame:IsA("Frame") and label and label:IsA("TextLabel")) then
        return
    end

    if type(attach_auto_resize) == "function" and attach_auto_resize ~= safe_attach_auto_resize then
        pcall(function()
            attach_auto_resize(frame, label)
        end)
        return
    end

    local okMin, MIN_H = pcall(function()
        return MIN_HEIGHT
    end)
    if not okMin or type(MIN_H) ~= "number" then
        MIN_H = 60
    end

    pcall(function()
        label.TextWrapped = true
        if label.AutomaticSize ~= nil then
            label.AutomaticSize = Enum.AutomaticSize.Y
        end
        if frame.AutomaticSize ~= nil then
            frame.AutomaticSize = Enum.AutomaticSize.Y
        end
    end)

    local function apply_size()
        if not frame or not frame.Parent or not label or not label.Parent then
            return
        end

        local sc = find_scroll_frame()
        local scW = (sc and sc.AbsoluteSize and sc.AbsoluteSize.X) or 400

        local ok, ts = pcall(function()
            return TextService:GetTextSize(
                tostring(label.Text or ""),
                label.TextSize or 16,
                label.Font or Enum.Font.SourceSans,
                Vector2.new(math.max(10, scW * 0.88), math.huge)
            )
        end)

        local textHeight = (ok and ts and ts.Y) and ts.Y or ((label.TextSize or 16) * 1.2)
        local newH = math.clamp(math.ceil(textHeight) + 18, MIN_H, 200)

        if frame.AutomaticSize == nil then
            pcall(function()
                frame.Size = UDim2.new(0.96, 0, 0, newH)
            end)
        end

        update_canvas(sc)
    end

    task.spawn(function()
        task.wait(0.02)
        apply_size()
    end)

    local conText = label:GetPropertyChangedSignal("Text"):Connect(function()
        task.defer(function()
            task.wait(0.02)
            apply_size()
        end)
    end)

    local conAbs = label:GetPropertyChangedSignal("AbsoluteSize"):Connect(function()
        task.defer(function()
            task.wait(0.01)
            apply_size()
        end)
    end)

    local ancCon
    ancCon = frame.AncestryChanged:Connect(function()
        if not frame:IsDescendantOf(game) then
            pcall(function()
                if conText and conText.Disconnect then conText:Disconnect() end
                if conAbs and conAbs.Disconnect then conAbs:Disconnect() end
                if ancCon and ancCon.Disconnect then ancCon:Disconnect() end
            end)
        end
    end)
end

attach_auto_resize = safe_attach_auto_resize

--// Typewriter + sound
local isAITyping = false

local function playSound(soundId, parent)
    if not soundId then return end
    local s = Instance.new("Sound")
    s.SoundId = "rbxassetid://" .. tostring(soundId)
    s.Volume = 0.2
    s.Parent = parent or CoreGui
    pcall(function()
        s:Play()
    end)
    task.delay(2, function()
        safeDestroy(s)
    end)
end

local function typewrite(label, fullText, delayPerChar, soundId, callback)
    if not (label and label:IsA("TextLabel")) then
        if callback then callback() end
        return
    end

    fullText = tostring(fullText or "")
    delayPerChar = tonumber(delayPerChar) or 0.02
    label.Text = ""

    task.spawn(function()
        for i = 1, #fullText do
            if not label or not label.Parent then
                break
            end
            pcall(function()
                label.Text = string.sub(fullText, 1, i)
                playSound(soundId, label)
            end)
            task.wait(delayPerChar)
        end
        if callback then callback() end
    end)
end

local function lockTextbox(box, locked)
    if not (box and box:IsA("TextBox")) then return end
    pcall(function()
        box.Active = not locked
        box.Selectable = not locked
        box.TextEditable = not locked
        box.PlaceholderText = locked and "[Thinking...]" or "Ask anything..."
    end)
end

--// Chat frame creators
local function make_row(kind, text, offset)
    local row = Instance.new("Frame")
    row.Name = kind
    row.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    row.BackgroundTransparency = 0.8
    row.Size = UDim2.new(0.96, 0, 0, tonumber(offset) or MIN_HEIGHT)
    row.Parent = Scroll
    createUIListLayout(row, 0, 10, Enum.HorizontalAlignment.Center, Enum.VerticalAlignment.Center, Enum.SortOrder.Name, Enum.FillDirection.Horizontal)
    Stroke(row, ASMBorder, 255, 255, 255, LJMRound, 1, 0)
    Corner(0, 8, row)
    return row
end

local function ai(Text, Offset)
    isAITyping = true
    lockTextbox(box, true)

    local row = make_row("ai", Text, Offset)
    local image = Instance.new("ImageLabel")
    image.Name = "a1"
    image.Image = "rbxassetid://83032822916288"
    image.Size = UDim2.new(0, 50, 0, 50)
    image.BackgroundTransparency = 0.8
    image.BackgroundColor3 = Color3.fromRGB(0, 170, 255)
    image.Parent = row
    Corner(0, 8, image)
    Stroke(image, ASMBorder, 255, 255, 255, LJMRound, 1, 0)

    local text = Instance.new("TextLabel")
    text.Name = "a2"
    text.Size = UDim2.new(0.88, -8, 1, 0)
    text.BackgroundTransparency = 1
    text.AutomaticSize = Enum.AutomaticSize.Y
    text.TextSize = 15
    text.TextWrapped = true
    text.TextXAlignment = Enum.TextXAlignment.Left
    text.TextYAlignment = Enum.TextYAlignment.Top
    text.Parent = row

    typewrite(text, Text or "Thinking...", 0.02, 18439142106, function()
        isAITyping = false
        lockTextbox(box, false)
    end)

    attach_auto_resize(row, text)
    update_canvas(Scroll)
    return row
end

local function plr(Text, Offset)
    local row = make_row("plr", Text, Offset)

    local image = Instance.new("ImageLabel")
    image.Name = "a2"
    image.Image = "rbxassetid://135474395711579"
    image.Size = UDim2.new(0, 50, 0, 50)
    image.BackgroundTransparency = 0.8
    image.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    image.Parent = row
    Corner(0, 8, image)
