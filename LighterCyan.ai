    local text = Instance.new("TextLabel")
    text.Name = "a1"
    text.Size = UDim2.new(0.88, -8, 1, 0)
    text.BackgroundTransparency = 1
    text.AutomaticSize = Enum.AutomaticSize.Y
    text.TextSize = 15
    text.TextWrapped = true
    text.TextXAlignment = Enum.TextXAlignment.Right
    text.TextYAlignment = Enum.TextYAlignment.Top
    text.Parent = row

    typewrite(text, Text or "", 0.02, 1289263994)
    attach_auto_resize(row, text)
    update_canvas(Scroll)
    return row
end

local function mesg(Text, Offset, R, G, B, R1, G1, B1)
    local row = Instance.new("Frame")
    row.Name = "message"
    row.BackgroundColor3 = Color3.fromRGB(R or 255, G or 255, B or 255)
    row.BackgroundTransparency = 0.8
    row.Size = UDim2.new(0.96, 0, 0, tonumber(Offset) or MIN_HEIGHT)
    row.Parent = Scroll
    createUIListLayout(row, 0, 10, Enum.HorizontalAlignment.Center, Enum.VerticalAlignment.Center, Enum.SortOrder.Name, Enum.FillDirection.Horizontal)
    Stroke(row, ASMBorder, 255, 255, 255, LJMRound, 1, 0)
    Corner(0, 8, row)

    local text = Instance.new("TextLabel")
    text.Name = "a1"
    text.Size = UDim2.new(0.88, 0, 1, 0)
    text.BackgroundTransparency = 1
    text.TextColor3 = Color3.fromRGB(R1 or 0, G1 or 0, B1 or 0)
    text.AutomaticSize = Enum.AutomaticSize.Y
    text.TextSize = 15
    text.TextWrapped = true
    text.TextXAlignment = Enum.TextXAlignment.Center
    text.TextYAlignment = Enum.TextYAlignment.Center
    text.Parent = row

    typewrite(text, Text or "", 0.02, 263105619)
    attach_auto_resize(row, text)
    update_canvas(Scroll)
    return row
end

