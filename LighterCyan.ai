    Players = game:GetService("Players")
    CoreGui = game:GetService("CoreGui")
    HttpService = game:GetService("HttpService")
    TextService = game:GetService("TextService")
end)

if not ok1 or not Players or not CoreGui then
    warn("[LC] Critical services unavailable")
    return
end

local player = Players.LocalPlayer
if not player then
    warn("[LC] No LocalPlayer available")
    return
end

--// Forward declarations for function references
local find_lightercyan_gui
local get_lightercyan_inset
local find_scroll_frame
local update_canvas
local attach_auto_resize

--// Connection tracker for memory safety
local ConnectionTracker = {}
ConnectionTracker.__index = ConnectionTracker

function ConnectionTracker.new()
    return setmetatable({ connections = {} }, ConnectionTracker)
end

function ConnectionTracker:add(signal, connection)
    if connection and type(connection.Disconnect) == "function" then
        table.insert(self.connections, connection)
    end
    return connection
end

function ConnectionTracker:disconnect_all()
    for _, conn in ipairs(self.connections) do
        pcall(function()
            if conn and type(conn.Disconnect) == "function" then
                conn:Disconnect()
            end
        end)
    end
    self.connections = {}
end

--// Configuration
local Config = {
    DEBUG = false,
    GUI_WAIT_TIMEOUT = 12,
    THINKING_BASE = "Thinking",
    MIN_HEIGHT = 60,
    MAX_HEIGHT = 200,
    TEXT_DELAY = 0.02,
}

--// Debug helper
local function dbg(...)
    if not Config.DEBUG then return end
    local t = { "[LC]" }
    for i = 1, select("#", ...) do
        t[#t + 1] = tostring(select(i, ...))
    end
    pcall(function()
        print(table.unpack(t))
    end)
end

--// Safe destroy with error handling
local function safeDestroy(obj)
    pcall(function()
        if obj and type(obj.Destroy) == "function" then
            obj:Destroy()
        end
    end)
end

--// Safe property setter with type validation
local function safeSet(obj, property, value)
    if not obj then return false end
    local ok = pcall(function()
        obj[property] = value
    end)
    return ok
end

--// Safe getter with fallback
local function safeGet(obj, property, fallback)
    if not obj then return fallback end
    local ok, result = pcall(function()
        return obj[property]
    end)
    return ok and result or fallback
end

--// UICorner creation with deduplication
local function Corner(scale, offset, parent)
    if not parent or type(parent.FindFirstChildOfClass) ~= "function" then
        return nil
    end
    
    local ok, corner = pcall(function()
        local existing = parent:FindFirstChildOfClass("UICorner")
        if existing then return existing end
        local new = Instance.new("UICorner")
        new.CornerRadius = UDim.new(scale or 0, offset or 0)
        new.Parent = parent
        return new
    end)
    return ok and corner or nil
end

--// UIListLayout with deduplication
local function createUIListLayout(parent, scale, offset, HZ, VT, SO, FILL)
    if not parent or type(parent.FindFirstChildOfClass) ~= "function" then
        return nil
    end
    
    local ok, list = pcall(function()
        local existing = parent:FindFirstChildOfClass("UIListLayout")
        if existing then return existing end
        
        local new = Instance.new("UIListLayout")
        new.Padding = UDim.new(scale or 0, offset or 0)
        new.FillDirection = FILL or Enum.FillDirection.Horizontal
        new.HorizontalAlignment = HZ or Enum.HorizontalAlignment.Center
        new.VerticalAlignment = VT or Enum.VerticalAlignment.Center
        new.SortOrder = SO or Enum.SortOrder.Name
        new.Parent = parent
        return new
    end)
    return ok and list or nil
end

--// Enum caching to prevent enum retrieval errors
local Enums = {}
pcall(function()
    Enums.ASMBorder = Enum.ApplyStrokeMode.Border
    Enums.ASMContextual = Enum.ApplyStrokeMode.Contextual
    Enums.LJMBevel = Enum.LineJoinMode.Bevel
    Enums.LJMMiter = Enum.LineJoinMode.Miter
    Enums.LJMRound = Enum.LineJoinMode.Round
end)

--// UIStroke creation with safe enum access
local function Stroke(parent, ASM, R, G, B, LJM, Tn, Transy)
    if not parent or type(parent.FindFirstChildOfClass) ~= "function" then
        return nil
    end
    
    local ok, stroke = pcall(function()
        local existing = parent:FindFirstChildOfClass("UIStroke")
        if existing then return existing end
        
        local new = Instance.new("UIStroke")
        new.ApplyStrokeMode = ASM or Enums.ASMBorder or Enum.ApplyStrokeMode.Border
        new.Color = Color3.fromRGB(
            tonumber(R) or 255,
            tonumber(G) or 255,
            tonumber(B) or 255
        )
        new.LineJoinMode = LJM or Enums.LJMRound or Enum.LineJoinMode.Round
        new.Thickness = tonumber(Tn) or 1
        new.Transparency = tonumber(Transy) or 0
        new.Parent = parent
        return new
    end)
    return ok and stroke or nil
end

--// UIGradient creation with robust color handling
local function Gradient(parent, rotation, offsetX, offsetY, ...)
    if not parent or type(parent.FindFirstChildOfClass) ~= "function" then
        return nil
    end
    
    local ok, grad = pcall(function()
        local existing = parent:FindFirstChildOfClass("UIGradient")
        if existing then return existing end
        
        local new = Instance.new("UIGradient")
        new.Rotation = tonumber(rotation) or 0
        new.Offset = Vector2.new(tonumber(offsetX) or 0, tonumber(offsetY) or 0)

        local colors = { ... }
        local keypoints = {}

        if #colors == 0 then
            keypoints = {
                ColorSequenceKeypoint.new(0, Color3.new(1, 1, 1)),
                ColorSequenceKeypoint.new(1, Color3.new(1, 1, 1)),
            }
        elseif #colors == 1 then
            keypoints = {
                ColorSequenceKeypoint.new(0, colors[1]),
                ColorSequenceKeypoint.new(1, colors[1]),
            }
        else
            for i, c in ipairs(colors) do
                local t = (i - 1) / (#colors - 1)
                table.insert(keypoints, ColorSequenceKeypoint.new(t, c))
            end
        end

        new.Color = ColorSequence.new(keypoints)
        new.Parent = parent
        return new
    end)
    return ok and grad or nil
end

--// UIPadding creation
local function Padding(parent, bottom, left, right, top)
    if not parent or type(parent.FindFirstChildOfClass) ~= "function" then
        return nil
    end
    
    local function toUDim(value)
        if typeof(value) == "UDim" then
            return value
        elseif type(value) == "number" then
            return UDim.new(0, value)
        elseif type(value) == "table" and #value >= 2 then
            return UDim.new(tonumber(value[1]) or 0, tonumber(value[2]) or 0)
        else
            return UDim.new(0, 0)
        end
    end

    local ok, pad = pcall(function()
        local existing = parent:FindFirstChildOfClass("UIPadding")
        if existing then return existing end
        
        local new = Instance.new("UIPadding")
        new.PaddingBottom = toUDim(bottom)
        new.PaddingLeft = toUDim(left)
        new.PaddingRight = toUDim(right)
        new.PaddingTop = toUDim(top)
        new.Parent = parent
        return new
    end)
    return ok and pad or nil
end

--// Safe GUI parent with multiple fallbacks
local function get_gui_parent()
    local ok, result = pcall(function()
        local cg = CoreGui
        if cg and type(cg.FindFirstChild) == "function" then
            local topBar = cg:FindFirstChild("TopBarApp")
            if topBar and type(topBar.FindFirstChild) == "function" then
                topBar = topBar:FindFirstChild("TopBarApp")
                if topBar and type(topBar.FindFirstChild) == "function" then
                    local unibar = topBar:FindFirstChild("UnibarLeftFrame")
                    if unibar and type(unibar.FindFirstChild) == "function" then
                        local health = unibar:FindFirstChild("HealthBar")
                        if health and type(health.FindFirstChild) == "function" then
                            local exp = health:FindFirstChild("ExperienceSettings")
                            if exp then return exp end
                        end
                    end
                end
            end
        end
        local pg = player:FindFirstChildOfClass("PlayerGui")
        return pg or cg
    end)
    if ok and result then
        return result
    end
    return pcall(function()
        return player:FindFirstChildOfClass("PlayerGui") or CoreGui
    end) and result or CoreGui
end

--// Find existing LighterCyan GUI
find_lightercyan_gui = function()
    local root = pcall(function()
        return player:FindFirstChildOfClass("PlayerGui") or CoreGui
    end) and result
    if not root then root = CoreGui end
    
    local ok1, gui1 = pcall(function()
        return root:FindFirstChild("LighterCyan.ai")
    end)
    if ok1 and gui1 and pcall(function() return gui1:IsA("ScreenGui") end) then
        return gui1
    end
    
    local ok2, gui2 = pcall(function()
        return CoreGui:FindFirstChild("LighterCyan.ai")
    end)
    if ok2 and gui2 and pcall(function() return gui2:IsA("ScreenGui") end) then
        return gui2
    end
    
    return nil
end

--// Get inset frame safely
get_lightercyan_inset = function()
    local gui = find_lightercyan_gui()
    if not gui or type(gui.FindFirstChild) ~= "function" then
        return nil
    end

    local ok1, holder = pcall(function()
        return gui:FindFirstChild("Holder")
    end)
    if not (ok1 and holder and type(holder.FindFirstChild) == "function") then
        return nil
    end

    local ok2, inset = pcall(function()
        return holder:FindFirstChild("InsetFrame")
    end)
    if ok2 and inset and pcall(function() return inset:IsA("Frame") end) then
        return inset
    end
    return nil
end

--// Wait for GUI with timeout
local function wait_for_gui(timeout)
    timeout = tonumber(timeout) or Config.GUI_WAIT_TIMEOUT
    local t0 = os.clock()
    repeat
        local inset = get_lightercyan_inset()
        if inset then
            return inset
        end
        task.wait(0.06)
    until os.clock() - t0 > timeout
    return nil
end

--// Find scroll frame with robust search
find_scroll_frame = function()
    local inset = get_lightercyan_inset()
    if not inset or type(inset.FindFirstChild) ~= "function" then
        return nil
    end

    local ok1, chat = pcall(function()
        return inset:FindFirstChild("a2_Chat")
    end)
    if not (ok1 and chat) and type(inset.GetDescendants) == "function" then
        local ok2, descendants = pcall(function()
            return inset:GetDescendants()
        end)
        if ok2 and descendants then
            for _, v in ipairs(descendants) do
                if pcall(function() return v:IsA("Frame") end) and v.Name == "a2_Chat" then
                    chat = v
                    break
                end
            end
        end
    end

    if chat and type(chat.FindFirstChild) == "function" then
        local ok3, scroll = pcall(function()
            return chat:FindFirstChild("Chat")
        end)
        if ok3 and scroll and pcall(function() return scroll:IsA("ScrollingFrame") end) then
            return scroll
        end
        if pcall(function() return chat:IsA("ScrollingFrame") end) then
            return chat
        end
    end

    if type(inset.GetDescendants) == "function" then
        local ok4, descendants = pcall(function()
            return inset:GetDescendants()
        end)
        if ok4 and descendants then
            for _, v in ipairs(descendants) do
                if pcall(function() return v:IsA("ScrollingFrame") and v.Name == "Chat" end) then
                    return v
                end
            end
        end
    end

    return nil
end

--// Canvas update with robust UIListLayout handling
update_canvas = function(scroll)
    if not scroll or type(scroll.IsA) ~= "function" or not pcall(function() return scroll:IsA("ScrollingFrame") end) then
        return
    end

    local ok1, layout = pcall(function()
        return scroll:FindFirstChildOfClass("UIListLayout")
    end)
    
    if ok1 and layout then
        task.defer(function()
            local ok2, size = pcall(function()
                return layout.AbsoluteContentSize
            end)
            if ok2 and size and type(size.Y) == "number" then
                pcall(function()
                    local absY = safeGet(scroll, "AbsoluteSize", Vector2.new()).Y or 0
                    safeSet(scroll, "CanvasSize", UDim2.new(0, 0, 0, math.max(size.Y + 8, absY)))
                    safeSet(scroll, "CanvasPosition", Vector2.new(0, math.max(0, size.Y - absY)))
                end)
            end
        end)
        return
    end

    task.defer(function()
        pcall(function()
            if type(scroll.GetChildren) ~= "function" then return end
            local ok, children = pcall(function()
                return scroll:GetChildren()
            end)
            if not ok or not children then return end
            
            local totalY = 0
            for _, c in ipairs(children) do
                if type(c.IsA) == "function" and pcall(function() return c:IsA("Frame") end) then
                    local absY = safeGet(c, "AbsoluteSize", Vector2.new()).Y or Config.MIN_HEIGHT
                    totalY = totalY + (tonumber(absY) or Config.MIN_HEIGHT) + 8
                end
            end
            
            local scrollAbsY = safeGet(scroll, "AbsoluteSize", Vector2.new()).Y or 0
            safeSet(scroll, "CanvasSize", UDim2.new(0, 0, 0, math.max(totalY, scrollAbsY)))
        end)
    end)
end

--// Destroy old GUI
