local jobCounter = 0
local sendLock = false

local function show_error(msg)
    mesg(tostring(msg or "Unknown error"), Config.MIN_HEIGHT, 255, 200, 200, 255, 50, 50)
end

local function safe_connect(btn, fn)
    if not btn or type(fn) ~= "function" then return nil end
    local ok, conn = pcall(function()
        if type(btn.IsA) == "function" and pcall(function() return btn:IsA("GuiButton") end) then
            return btn.Activated:Connect(fn)
        elseif type(btn.MouseButton1Click) ~= "nil" then
            return btn.MouseButton1Click:Connect(fn)
        end
        return nil
    end)
    return ok and conn or nil
end

