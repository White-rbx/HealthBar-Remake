--// Auto-resize helper with connection tracking
local ResizeConnections = ConnectionTracker.new()

local function safe_attach_auto_resize(frame, label)
    if not (frame and label) then return end
    if type(frame.IsA) ~= "function" or type(label.IsA) ~= "function" then return end
    
    local frameValid = pcall(function() return frame:IsA("Frame") end)
    local labelValid = pcall(function() return label:IsA("TextLabel") end)
    if not (frameValid and labelValid) then return end

    -- Pre-setup
    pcall(function()
        label.TextWrapped = true
        if label.AutomaticSize ~= nil then
            label.AutomaticSize = Enum.AutomaticSize.Y
        end
        if frame.AutomaticSize ~= nil then
            frame.AutomaticSize = Enum.AutomaticSize.Y
        end
    end)

    local function apply_size()
        if not (frame and frame.Parent and label and label.Parent) then return end
        
        pcall(function()
            local sc = find_scroll_frame()
            local scW = (sc and type(sc.AbsoluteSize) ~= "nil" and sc.AbsoluteSize.X) or 400

            local ok, ts = pcall(function()
                return TextService:GetTextSize(
                    tostring(safeGet(label, "Text", "")),
                    tonumber(safeGet(label, "TextSize", 16)) or 16,
                    safeGet(label, "Font", Enum.Font.SourceSans),
                    Vector2.new(math.max(10, scW * 0.88), math.huge)
                )
            end)

            local textHeight = (ok and ts and type(ts.Y) == "number") and ts.Y or ((tonumber(safeGet(label, "TextSize", 16)) or 16) * 1.2)
            local newH = math.clamp(math.ceil(textHeight) + 18, Config.MIN_HEIGHT, Config.MAX_HEIGHT)

            if safeGet(frame, "AutomaticSize", nil) == nil then
                safeSet(frame, "Size", UDim2.new(0.96, 0, 0, newH))
            end

            update_canvas(sc)
        end)
    end

    -- Spawn initial size
    task.spawn(function()
        task.wait(0.02)
        apply_size()
    end)

    -- Text change listener
    local conText
    pcall(function()
        conText = label:GetPropertyChangedSignal("Text"):Connect(function()
            task.defer(function()
                task.wait(0.02)
                apply_size()
            end)
        end)
        if conText then
            ResizeConnections:add("text", conText)
        end
    end)

    -- Absolute size change listener
    local conAbs
    pcall(function()
        conAbs = label:GetPropertyChangedSignal("AbsoluteSize"):Connect(function()
            task.defer(function()
                task.wait(0.01)
                apply_size()
            end)
        end)
        if conAbs then
            ResizeConnections:add("abs", conAbs)
        end
    end)

    -- Cleanup on ancestry change
    local ancCon
    pcall(function()
        ancCon = frame.AncestryChanged:Connect(function()
            pcall(function()
                if not frame or not frame:IsDescendantOf(game) then
                    if conText then pcall(function() conText:Disconnect() end) end
                    if conAbs then pcall(function() conAbs:Disconnect() end) end
                    if ancCon then pcall(function() ancCon:Disconnect() end) end
                end
            end)
        end)
        if ancCon then
            ResizeConnections:add("anc", ancCon)
        end
    end)
end

attach_auto_resize = safe_attach_auto_resize

--// Typewriter effect with sound
local isAITyping = false

local function playSound(soundId, parent)
    if not soundId or type(soundId) ~= "number" then return end
    
    pcall(function()
        local s = Instance.new("Sound")
        safeSet(s, "SoundId", "rbxassetid://" .. tostring(soundId))
        safeSet(s, "Volume", 0.2)
        safeSet(s, "Parent", parent or CoreGui)
        pcall(function()
            if type(s.Play) == "function" then
                s:Play()
            end
        end)
        task.delay(2, function()
            safeDestroy(s)
        end)
    end)
end

local function typewrite(label, fullText, delayPerChar, soundId, callback)
    if not label or type(label.IsA) ~= "function" or not pcall(function() return label:IsA("TextLabel") end) then
        if callback then pcall(function() callback() end) end
        return
    end

    fullText = tostring(fullText or "")
    delayPerChar = tonumber(delayPerChar) or Config.TEXT_DELAY
    safeSet(label, "Text", "")

    task.spawn(function()
        for i = 1, #fullText do
            if not (label and label.Parent) then
                break
            end
            pcall(function()
                safeSet(label, "Text", string.sub(fullText, 1, i))
                playSound(soundId, label)
            end)
            task.wait(delayPerChar)
        end
        if callback then pcall(function() callback() end) end
    end)
end

local function lockTextbox(box, locked)
    if not box or type(box.IsA) ~= "function" or not pcall(function() return box:IsA("TextBox") end) then return end
    pcall(function()
        safeSet(box, "Active", not locked)
        safeSet(box, "Selectable", not locked)
        safeSet(box, "TextEditable", not locked)
        safeSet(box, "PlaceholderText", locked and "[Thinking...]" or "Ask anything...")
    end)
end

--// Chat row creators
local function make_row(kind, text, offset)
    local row
    pcall(function()
        row = Instance.new("Frame")
        safeSet(row, "Name", kind)
        safeSet(row, "BackgroundColor3", Color3.fromRGB(255, 255, 255))
        safeSet(row, "BackgroundTransparency", 0.8)
        safeSet(row, "Size", UDim2.new(0.96, 0, 0, tonumber(offset) or Config.MIN_HEIGHT))
        safeSet(row, "Parent", Scroll)
        createUIListLayout(row, 0, 10, Enum.HorizontalAlignment.Center, Enum.VerticalAlignment.Center, Enum.SortOrder.Name, Enum.FillDirection.Horizontal)
        Stroke(row, Enums.ASMBorder, 255, 255, 255, Enums.LJMRound, 1, 0)
        Corner(0, 8, row)
    end)
    return row
end

local function ai(Text, Offset)
    pcall(function()
        isAITyping = true
        lockTextbox(box, true)

        local row = make_row("ai", Text, Offset)
        if not row then return end
        
        local image
        pcall(function()
            image = Instance.new("ImageLabel")
            safeSet(image, "Name", "a1")
            safeSet(image, "Image", "rbxassetid://83032822916288")
            safeSet(image, "Size", UDim2.new(0, 50, 0, 50))
            safeSet(image, "BackgroundTransparency", 0.8)
            safeSet(image, "BackgroundColor3", Color3.fromRGB(0, 170, 255))
            safeSet(image, "Parent", row)
            Corner(0, 8, image)
            Stroke(image, Enums.ASMBorder, 255, 255, 255, Enums.LJMRound, 1, 0)
        end)

        local text
        pcall(function()
            text = Instance.new("TextLabel")
            safeSet(text, "Name", "a2")
            safeSet(text, "Size", UDim2.new(0.88, -8, 1, 0))
            safeSet(text, "BackgroundTransparency", 1)
            safeSet(text, "AutomaticSize", Enum.AutomaticSize.Y)
            safeSet(text, "TextSize", 15)
            safeSet(text, "TextWrapped", true)
            safeSet(text, "TextXAlignment", Enum.TextXAlignment.Left)
            safeSet(text, "TextYAlignment", Enum.TextYAlignment.Top)
            safeSet(text, "Parent", row)

            typewrite(text, Text or "Thinking...", Config.TEXT_DELAY, 18439142106, function()
                isAITyping = false
                lockTextbox(box, false)
            end)

            attach_auto_resize(row, text)
        end)
        
        update_canvas(Scroll)
    end)
end

