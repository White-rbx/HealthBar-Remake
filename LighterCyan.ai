-- LighterCyan.ai - stabilized build
-- Fixes:
-- 1) wrong stroke enum typo (LSMRound -> LJMRound)
-- 2) nil-order issues by forward-declaring helpers
-- 3) safer GUI parent fallback
-- 4) duplicate UIListLayout prevention
-- 5) safer resize/canvas updates
-- 6) hook connection dedupe
-- 7) pcall wrappers around unstable external calls

--// External loader (kept, but safely wrapped)
pcall(function()
    if type(loadstring) == "function" and game and game.HttpGet then
        loadstring(game:HttpGet("https://raw.githubusercontent.com/White-rbx/LigherCyan.ai/refs/heads/main/Loader.lua"))()
    end
end)

--// Services
local Players = game:GetService("Players")
local CoreGui = game:GetService("CoreGui")
local HttpService = game:GetService("HttpService")
local TextService = game:GetService("TextService")
local player = Players.LocalPlayer
if not player then
    warn("[LC] No LocalPlayer")
    return
end

--// Forward declarations (important for nil-order stability)
local find_lightercyan_gui
local get_lightercyan_inset
local find_scroll_frame
local update_canvas
local attach_auto_resize

--// Config
local DEBUG = false
local GUI_WAIT_TIMEOUT = 12
local THINKING_BASE = "Thinking"
local MIN_HEIGHT = 60

--// Debug helper
local function dbg(...)
    if not DEBUG then return end
    local t = { "[LC]" }
    for i = 1, select("#", ...) do
        t[#t + 1] = tostring(select(i, ...))
    end
    pcall(function()
        print(table.unpack(t))
    end)
end

--// Small helpers
local function safeDestroy(obj)
    pcall(function()
        if obj then obj:Destroy() end
    end)
end

local function Corner(scale, offset, parent)
    if not parent then return nil end
    local corner = parent:FindFirstChildOfClass("UICorner") or Instance.new("UICorner")
    corner.CornerRadius = UDim.new(scale or 0, offset or 0)
    corner.Parent = parent
    return corner
end

local function createUIListLayout(parent, scale, offset, HZ, VT, SO, FILL)
    if not parent then return nil end
    local existing = parent:FindFirstChildOfClass("UIListLayout")
    local list = existing or Instance.new("UIListLayout")
    list.Padding = UDim.new(scale or 0, offset or 0)
    list.FillDirection = FILL or Enum.FillDirection.Horizontal
    list.HorizontalAlignment = HZ or Enum.HorizontalAlignment.Center
    list.VerticalAlignment = VT or Enum.VerticalAlignment.Center
    list.SortOrder = SO or Enum.SortOrder.Name
    list.Parent = parent
    return list
end

local ASMBorder = Enum.ApplyStrokeMode.Border
local ASMContextual = Enum.ApplyStrokeMode.Contextual
local LJMBevel = Enum.LineJoinMode.Bevel
local LJMMiter = Enum.LineJoinMode.Miter
local LJMRound = Enum.LineJoinMode.Round

local function Stroke(parent, ASM, R, G, B, LJM, Tn, Transy)
    if not parent then return nil end
    local stroke = parent:FindFirstChildOfClass("UIStroke") or Instance.new("UIStroke")
    stroke.ApplyStrokeMode = ASM or ASMBorder
    stroke.Color = Color3.fromRGB(R or 255, G or 255, B or 255)
    stroke.LineJoinMode = LJM or LJMRound
    stroke.Thickness = Tn or 1
    stroke.Transparency = Transy or 0
    stroke.Parent = parent
    return stroke
end

local function Gradient(parent, rotation, offsetX, offsetY, ...)
    if not parent then return nil end
    local grad = parent:FindFirstChildOfClass("UIGradient") or Instance.new("UIGradient")
    grad.Rotation = rotation or 0
    grad.Offset = Vector2.new(offsetX or 0, offsetY or 0)

    local colors = { ... }
    local keypoints = {}

    if #colors == 0 then
        keypoints = {
            ColorSequenceKeypoint.new(0, Color3.new(1, 1, 1)),
            ColorSequenceKeypoint.new(1, Color3.new(1, 1, 1)),
        }
    elseif #colors == 1 then
        keypoints = {
            ColorSequenceKeypoint.new(0, colors[1]),
            ColorSequenceKeypoint.new(1, colors[1]),
        }
    else
        for i, c in ipairs(colors) do
            local t = (i - 1) / (#colors - 1)
            table.insert(keypoints, ColorSequenceKeypoint.new(t, c))
        end
    end

    grad.Color = ColorSequence.new(keypoints)
    grad.Parent = parent
    return grad
end

local function Padding(parent, bottom, left, right, top)
    if not parent then return nil end
    local pad = parent:FindFirstChildOfClass("UIPadding") or Instance.new("UIPadding")
    local function toUDim(value)
        if typeof(value) == "UDim" then
            return value
        elseif type(value) == "number" then
            return UDim.new(0, value)
        elseif type(value) == "table" and #value >= 2 then
            return UDim.new(value[1] or 0, value[2] or 0)
        else
            return UDim.new(0, 0)
        end
    end

    pad.PaddingBottom = toUDim(bottom)
    pad.PaddingLeft = toUDim(left)
    pad.PaddingRight = toUDim(right)
    pad.PaddingTop = toUDim(top)
    pad.Parent = parent
    return pad
end

--// Safer GUI location
local function get_gui_parent()
    local ok, result = pcall(function()
        local cg = CoreGui
        local topBar = cg:FindFirstChild("TopBarApp")
        if topBar then
            topBar = topBar:FindFirstChild("TopBarApp")
            local unibar = topBar and topBar:FindFirstChild("UnibarLeftFrame")
            local health = unibar and unibar:FindFirstChild("HealthBar")
            local exp = health and health:FindFirstChild("ExperienceSettings")
            if exp then
                return exp
            end
        end
        local pg = player:FindFirstChildOfClass("PlayerGui")
        return pg or cg
    end)
    if ok and result then
        return result
    end
    return player:FindFirstChildOfClass("PlayerGui") or CoreGui
end

local function find_lightercyan_gui()
    local root = player:FindFirstChildOfClass("PlayerGui") or CoreGui
    local gui = root and root:FindFirstChild("LighterCyan.ai")
    if gui and gui:IsA("ScreenGui") then
        return gui
    end
    gui = CoreGui:FindFirstChild("LighterCyan.ai")
    if gui and gui:IsA("ScreenGui") then
        return gui
    end
    return nil
end

local function get_lightercyan_inset()
    local gui = find_lightercyan_gui()
    if not gui then return nil end

    local holder = gui:FindFirstChild("Holder")
    if not holder then return nil end

    local inset = holder:FindFirstChild("InsetFrame")
    if inset and inset:IsA("Frame") then
        return inset
    end
    return nil
end

local function wait_for_gui(timeout)
    timeout = timeout or GUI_WAIT_TIMEOUT
    local t0 = os.clock()
    repeat
        local inset = get_lightercyan_inset()
        if inset then
            return inset
        end
        task.wait(0.06)
    until os.clock() - t0 > timeout
    return nil
end

find_scroll_frame = function()
    local inset = get_lightercyan_inset()
    if not inset then return nil end

    local chat = inset:FindFirstChild("a2_Chat")
    if not chat then
        for _, v in ipairs(inset:GetDescendants()) do
            if v:IsA("Frame") and v.Name == "a2_Chat" then
                chat = v
                break
            end
        end
    end

    if chat then
        local scroll = chat:FindFirstChild("Chat")
        if scroll and scroll:IsA("ScrollingFrame") then
            return scroll
        end
        if chat:IsA("ScrollingFrame") then
            return chat
        end
    end

    for _, v in ipairs(inset:GetDescendants()) do
        if v:IsA("ScrollingFrame") and v.Name == "Chat" then
            return v
        end
    end

    return nil
end

update_canvas = function(scroll)
    if not scroll or not scroll:IsA("ScrollingFrame") then return end

    local layout = scroll:FindFirstChildOfClass("UIListLayout")
    if layout then
        task.defer(function()
            local ok, size = pcall(function()
                return layout.AbsoluteContentSize
            end)
            if ok and size then
                pcall(function()
                    scroll.CanvasSize = UDim2.new(0, 0, 0, math.max(size.Y + 8, scroll.AbsoluteSize.Y or 0))
                    scroll.CanvasPosition = Vector2.new(0, math.max(0, size.Y - (scroll.AbsoluteSize.Y or 0)))
                end)
            end
        end)
        return
    end

    task.defer(function()
        local totalY = 0
        for _, c in ipairs(scroll:GetChildren()) do
            if c:IsA("Frame") then
                totalY += (c.AbsoluteSize.Y or MIN_HEIGHT) + 8
            end
        end
        pcall(function()
            scroll.CanvasSize = UDim2.new(0, 0, 0, math.max(totalY, scroll.AbsoluteSize.Y or 0))
        end)
    end)
end

