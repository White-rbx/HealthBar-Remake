local function btm(Name, Text, Pos)
    local btm1
    pcall(function()
        btm1 = Instance.new("Frame")
        safeSet(btm1, "Name", tostring(Name or ""))
        safeSet(btm1, "BackgroundColor3", Color3.fromRGB(255, 255, 255))
        safeSet(btm1, "BackgroundTransparency", 0.6)
        safeSet(btm1, "Size", UDim2.new(0.1, 0, 0, 50))
        safeSet(btm1, "Position", UDim2.new(Pos or 0, 0, 0, 0))
        safeSet(btm1, "Parent", option)
        Corner(0, 8, btm1)
        Stroke(btm1, Enums.ASMBorder, 255, 255, 255, Enums.LJMRound, 1, 0)

        local btm2 = Instance.new("TextButton")
        safeSet(btm2, "Size", UDim2.new(0.9, 0, 0.9, 0))
        safeSet(btm2, "Position", UDim2.new(0.05, 0, 0.05, 0))
        safeSet(btm2, "TextScaled", true)
        safeSet(btm2, "BackgroundTransparency", 1)
        safeSet(btm2, "Text", tostring(Text or ""))
        safeSet(btm2, "Parent", btm1)

        Gradient(btm2, 0, 0, 0, Color3.fromRGB(0, 0, 0), Color3.fromRGB(0, 0, 0))
    end)
    return btm1
end

